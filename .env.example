# RustMetrics — Environment-Variablen
# Auf dem Server unter /opt/rustmetrics/.env speichern, chmod 600.

# Wo lauscht der App-Server intern (hinter Caddy)
RM_HOST=127.0.0.1
RM_PORT=8765

# Postgres-Verbindung
RM_PGHOST=127.0.0.1
RM_PGPORT=5432
RM_PGUSER=rustmetrics
RM_PGPASSWORD=CHANGE-ME-RANDOM-PASSWORD-HERE
RM_PGDATABASE=rustmetrics

# Public-Origin (für Steam-OpenID-Callback und Cookie-Domain)
RM_ORIGIN=https://rustmetrics.eu

# Wer ist Admin? Komma-separierte Liste von SteamID64
RM_ADMIN_STEAMIDS=

# Steam Web API Key (OPTIONAL — nur für Profil-Avatar/Display-Name)
# Hol dir einen unter https://steamcommunity.com/dev/apikey
# Wenn leer, läuft Login trotzdem (User heisst dann nach SteamID, kein Avatar)
RM_STEAM_API_KEY=

# Wie lange ist eine Session gültig (Sekunden) — default 30 Tage
RM_SESSION_TTL=2592000

# Polling
RM_POLL_INTERVAL_SEC=20
RM_A2S_TIMEOUT_SEC=3.0
RM_SNAPSHOTS_KEEP_DAYS=14

# Browse-Cache (Steam-Master)
RM_BROWSE_CACHE_TTL=180
# Max. Server pro GetServerList-Call. Rust hat ~9-10k Server; die API hat
# keine Pagination und sortiert NICHT nach Population — unter ~10000 fehlen
# willkuerlich Server im Browser (z.B. Moose/Rustafied). 20000 = alles.
RM_BROWSE_MASTER_LIMIT=20000
RM_BROWSE_PARALLEL=80
RM_BROWSE_A2S_TIMEOUT=2.5

# Rate-Limits (pro IP)
RM_RL_BROWSE_PER_HOUR=12
RM_RL_REQUESTS_PER_MIN=120

# Caddy-Access-Log Pfad — wird von /admin/stats eingelesen.
# Der rustmetrics-User braucht Read-Permission auf die Datei
# (siehe README → setfacl -m u:rustmetrics:r /var/log/caddy/rustmetrics.log).
# Leer lassen wenn die Page diesen Block nicht zeigen soll.
RM_CADDY_LOG=/var/log/caddy/rustmetrics.log
RM_CADDY_LOG_MAX_BYTES=5242880
